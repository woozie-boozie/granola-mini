# Copy to .env and fill in.
# Get a key at https://console.deepgram.com (free tier includes plenty for a demo).
DEEPGRAM_API_KEY=

# Optional: override the model (nova-2 is the safe default; nova-3 if your account has it).
# DEEPGRAM_MODEL=nova-2

# For "Generate notes" (turns the transcript into a Granola-style summary with Claude).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
